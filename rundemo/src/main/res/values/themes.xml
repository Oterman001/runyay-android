<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ComopseDemoHub" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- uCrop 裁剪界面主题 - 修复状态栏重叠问题 -->
    <style name="Theme.UCrop" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">#FF6200EE</item>
        <item name="colorPrimaryDark">#FF3700B3</item>
        <item name="colorAccent">#FF6200EE</item>
        <!-- 确保内容不延伸到状态栏下 -->
        <item name="android:fitsSystemWindows">true</item>
    </style>
</resources>