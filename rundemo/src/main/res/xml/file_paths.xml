<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Cache directory for temporary avatar images -->
    <cache-path
        name="avatar_cache"
        path="." />

    <!-- Cache directory for share images -->
    <cache-path
        name="share_images"
        path="share_images" />

    <!-- Cache directory for exported log zip files -->
    <cache-path
        name="log_exports"
        path="log_exports" />

    <!-- External files directory for APK downloads -->
    <external-files-path
        name="apk_downloads"
        path="Downloads" />
</paths>
